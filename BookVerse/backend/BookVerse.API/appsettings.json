{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": { "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}" }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "shared": true,
          "outputTemplate": "[{Application}][{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithProcessId", "WithMachineName" ]
  },
  "ConnectionStrings": {
    "Main": ""
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "BookVerse.Api",
    "Audience": "BookVerse.Spa",
    "Key": "",
    "AccessTokenMinutes": 20,
    "RefreshTokenDays": 14
  },
  "CorsSettings": {
    "AllowedOrigins": [
      "https://localhost:7260",
      "http://localhost:5177",
      "http://localhost:4200"
    ]
  },
  "EmailSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromName": "BookVerse",
    "FromEmail": "",
    "SecureSocketOptions": "StartTls"
  },
  "Stripe": {
    "SecretKey": "",
    "PublishableKey": "",
    "WebhookSecret": ""
  },
  "Payment": {
    "Currency": "bam"
  },
  "CaptchaOptions": {
    "SecretKey": ""
  },
  "FrontendUrl": "http://localhost:4200"
}